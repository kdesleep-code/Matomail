<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% if mode == "new" %}追加指示の追加{% else %}追加指示の編集{% endif %} - Matomail</title>
    <style>
      :root {
        --bg: #f6f7f9;
        --surface: #ffffff;
        --text: #17202a;
        --muted: #64707d;
        --line: #d9dee5;
        --accent: #176b87;
        --accent-dark: #0f5268;
        --danger: #b42318;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: "Segoe UI", "Yu Gothic", Meiryo, sans-serif;
        line-height: 1.55;
      }
      main {
        width: min(860px, calc(100vw - 32px));
        margin: 32px auto;
        display: grid;
        gap: 16px;
      }
      .panel {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--surface);
        padding: 22px;
      }
      h1 { margin: 0; font-size: 26px; letter-spacing: 0; }
      .grid { display: grid; gap: 12px; margin-top: 16px; }
      label { display: grid; gap: 6px; font-weight: 700; }
      input[type="text"], textarea {
        width: 100%;
        border: 1px solid var(--line);
        border-radius: 6px;
        color: var(--text);
        font: inherit;
        padding: 9px 10px;
      }
      textarea { min-height: 130px; resize: vertical; }
      .inline {
        display: inline-flex;
        gap: 8px;
        align-items: center;
        font-weight: 700;
      }
      .hint {
        color: var(--muted);
        font-size: 13px;
      }
      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 18px;
      }
      button, a {
        min-height: 42px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        padding: 0 14px;
        font: inherit;
        font-weight: 700;
        text-decoration: none;
      }
      button {
        border: 0;
        background: var(--accent);
        color: white;
        cursor: pointer;
      }
      button:hover { background: var(--accent-dark); }
      a {
        border: 1px solid var(--line);
        background: white;
        color: var(--accent);
      }
      .error { color: var(--danger); font-weight: 700; }
    </style>
  </head>
  <body>
    <main>
      <section class="panel">
        <h1>{% if mode == "new" %}追加指示の追加{% else %}追加指示の編集{% endif %}</h1>
        {% if error %}<p class="error">{{ error }}</p>{% endif %}
        {% if mode == "new" or rule %}
          <form method="post" action="{% if mode == "new" %}/instructions/new{% else %}/instructions/{{ rule.id }}/edit{% endif %}">
            <div class="grid">
              <label>名前<input type="text" name="name" value="{{ rule.name if rule else '' }}"></label>
              <label>LLMへの追加指示<textarea name="instruction">{{ rule.instruction if rule else '' }}</textarea></label>
              <div class="hint">ここに書いた内容は、条件に一致したメールを分析するときだけプロンプトへ追加されます。</div>
              <div class="hint">複数の条件を入れた場合は、すべてに一致したメールだけが対象になります。</div>
              <label>送信アドレス<input type="text" name="from_query" value="{{ rule.from_query if rule else '' }}"></label>
              <label>受信アドレス<input type="text" name="to_query" value="{{ rule.to_query if rule else '' }}"></label>
              <label>件名<input type="text" name="subject_query" value="{{ rule.subject_query if rule else '' }}"></label>
              <label>本文などに含む<textarea name="has_words">{{ rule.has_words if rule else '' }}</textarea></label>
              <label>本文などに含まない<textarea name="doesnt_have">{{ rule.doesnt_have if rule else '' }}</textarea></label>
              <label>メモ<textarea name="note">{{ rule.note if rule else '' }}</textarea></label>
              <label class="inline"><input type="checkbox" name="enabled" {% if not rule or rule.enabled %}checked{% endif %}> 有効</label>
            </div>
            <div class="actions">
              <button type="submit">保存</button>
              <a href="/rules">優先度ルールに戻る</a>
            </div>
          </form>
        {% else %}
          <div class="actions">
            <a href="/rules">優先度ルールに戻る</a>
          </div>
        {% endif %}
      </section>
    </main>
  </body>
</html>
