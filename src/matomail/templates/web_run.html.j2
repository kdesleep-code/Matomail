<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>メール読み込み中 - Matomail</title>
    <style>
      :root {
        --bg: #f6f7f9;
        --surface: #ffffff;
        --text: #17202a;
        --muted: #64707d;
        --line: #d9dee5;
        --accent: #176b87;
        --danger: #b42318;
      }

      * {
        box-sizing: border-box;
      }

      body {
        min-height: 100vh;
        margin: 0;
        display: grid;
        place-items: center;
        background: var(--bg);
        color: var(--text);
        font-family: "Segoe UI", "Yu Gothic", Meiryo, sans-serif;
      }

      main {
        width: min(640px, calc(100vw - 32px));
        display: grid;
        gap: 16px;
        padding: 28px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--surface);
      }

      h1 {
        margin: 0;
        font-size: 26px;
        letter-spacing: 0;
      }

      .message {
        color: var(--muted);
      }

      .bar {
        width: 100%;
        height: 18px;
        overflow: hidden;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: #eef1f4;
      }

      .fill {
        width: {{ run.percent }}%;
        height: 100%;
        background: var(--accent);
        transition: width 240ms ease;
      }

      .details {
        display: flex;
        flex-wrap: wrap;
        gap: 8px 14px;
        color: var(--muted);
        font-size: 14px;
      }

      .error {
        color: var(--danger);
        white-space: pre-wrap;
      }

      a {
        color: var(--accent);
        font-weight: 700;
      }
    </style>
  </head>
  <body>
    <main>
      <h1 id="title">メール読み込み中</h1>
      <div class="message" id="message">{{ run.message }}</div>
      <div class="bar" aria-label="進捗">
        <div class="fill" id="fill"></div>
      </div>
      <div class="details">
        <span id="percent">{{ run.percent }}%</span>
        <span id="stage">{{ run.stage }}</span>
        <span id="counts"></span>
      </div>
      <div class="error" id="error"></div>
      <a href="/">読み込みページに戻る</a>
    </main>

    <script>
      const runId = "{{ run.run_id }}";
      const fill = document.querySelector("#fill");
      const percent = document.querySelector("#percent");
      const stage = document.querySelector("#stage");
      const message = document.querySelector("#message");
      const title = document.querySelector("#title");
      const counts = document.querySelector("#counts");
      const error = document.querySelector("#error");

      async function poll() {
        const response = await fetch(`/runs/${runId}/status`, { cache: "no-store" });
        const data = await response.json();
        fill.style.width = `${data.percent}%`;
        percent.textContent = `${data.percent}%`;
        stage.textContent = data.stage;
        message.textContent = data.message;
        counts.textContent = `取得 ${data.fetched_count} / 解析 ${data.analyzed_count}`;

        if (data.error) {
          title.textContent = "読み込みに失敗しました";
          error.textContent = data.error;
          return;
        }

        if (data.done && data.report_url) {
          title.textContent = "読み込み完了";
          window.location.href = data.report_url;
          return;
        }

        if (!data.done) {
          window.setTimeout(poll, 1000);
        }
      }

      poll();
    </script>
  </body>
</html>
